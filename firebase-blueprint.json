{
  "entities": {
    "Building": {
      "title": "Building",
      "description": "Represents a building in the project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "totalUnits": { "type": "number" }
      },
      "required": ["id", "projectId", "name", "totalUnits"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Represents a specific unit (apartment or public area) in a building",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "buildingId": { "type": "string" },
        "number": { "type": "number" },
        "statuses": {
          "type": "object",
          "properties": {
            "plumbing": { "type": "string" },
            "general": { "type": "string" }
          }
        }
      },
      "required": ["id", "projectId", "buildingId", "number", "statuses"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a construction project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "TaskLog": {
      "title": "TaskLog",
      "description": "A log entry for a task performed in a unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "workerName": { "type": "string" },
        "contractor": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "discipline": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "timestamp", "workerName", "contractor", "description", "status", "discipline"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment scheduled for a unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "tenantName": { "type": "string" },
        "contractor": { "type": "string" },
        "notes": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "date", "time", "tenantName", "contractor", "isCompleted", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "contractor", "viewer"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects"
    },
    "/buildings/{buildingId}": {
      "schema": "Building",
      "description": "Collection of buildings"
    },
    "/units/{unitId}": {
      "schema": "Unit",
      "description": "Collection of units"
    },
    "/units/{unitId}/logs/{logId}": {
      "schema": "TaskLog",
      "description": "Log entries for a unit"
    },
    "/units/{unitId}/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments for a unit"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
